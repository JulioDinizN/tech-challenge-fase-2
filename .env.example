# Local development values.
# Copy to .env when needed. Do not commit real credentials.

POSTGRES_USER=togglemaster
POSTGRES_PASSWORD=togglemaster_local_password
MASTER_KEY=admin-secreto-123
BOOTSTRAP_API_KEY=tm_key_local_development_only
SERVICE_API_KEY=tm_key_local_development_only
ANALYTICS_WORKER_ENABLED=false

# OCI values are used only by a future OKE deployment. Docker Compose does not
# inject them into the services, so the local stack remains cloud-independent.
OCI_AUTH_MODE=workload_identity
OCI_REGION=replace-with-oci-region
OCI_COMPARTMENT_OCID=replace-with-compartment-ocid
OCI_CONTAINER_REGISTRY_NAMESPACE=replace-with-ocir-namespace
OCI_QUEUE_OCID=replace-with-queue-ocid
OCI_QUEUE_MESSAGES_ENDPOINT=replace-with-queue-messages-endpoint
OCI_NOSQL_TABLE=ToggleMasterAnalytics

IMAGE_TAG=latest
