# Copy to backend.tf only after an OCI Object Storage state bucket exists.
# backend.tf is ignored because bucket/namespace/region are environment-specific.
terraform {
  backend "oci" {
    bucket              = "replace-with-terraform-state-bucket"
    namespace           = "replace-with-object-storage-namespace"
    key                 = "togglemaster/terraform.tfstate"
    region              = "sa-saopaulo-1"
    config_file_profile = "DEFAULT"
  }
}
