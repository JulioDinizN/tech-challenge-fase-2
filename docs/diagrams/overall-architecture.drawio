        <mxCell id="local-note-body" value="Valida 5 microsserviços + 4 dependências locais. Na OCI, os dados relacionais ficam em 3 sistemas PostgreSQL independentes e analytics usa OCI Queue + OCI NoSQL." style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;verticalAlign=middle;fontColor=#0f172a;fontSize=12;fontColor=#475569;fontStyle=1;" vertex="1" parent="1">
