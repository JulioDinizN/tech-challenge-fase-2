        <mxCell id="legend-text" value="Legenda: laranja = borda/registro OCI | azul = OKE/Ingress | verde = microsserviços | roxo = SQL/fila | vermelho = cache | azul-claro = NoSQL | tracejado verde-azulado = chamadas HTTP internas" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;verticalAlign=middle;fontColor=#0f172a;fontSize=11;fontColor=#475569;fontStyle=1;" vertex="1" parent="1">
